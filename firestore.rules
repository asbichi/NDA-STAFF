rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Auth Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "abdullahibichishuaib.ABS@gmail.com" ||
        request.auth.token.email == "admin@NDA.academy" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidStudent(data) {
      // name, admissionNo, class, arm, gender, createdAt = 6 fields
      return data.keys().hasAll(['name', 'admissionNo', 'class', 'arm', 'gender', 'createdAt']) &&
             data.size() == 6 &&
             data.name is string && data.name.size() <= 200 &&
             data.admissionNo is string && data.admissionNo.size() <= 50 &&
             data.class is string && data.class.size() <= 50 &&
             data.arm is string && data.arm.size() <= 10 &&
             data.gender is string && data.gender.size() <= 20 &&
             data.createdAt == request.time;
    }
    
    function isValidQuestion(data) {
      // subject, class, text, options, correctAnswer, createdAt = 6 fields
      return data.keys().hasAll(['subject', 'class', 'text', 'options', 'correctAnswer', 'createdAt']) &&
             data.size() == 6 &&
             data.subject is string && data.subject.size() <= 100 &&
             data.class is string && data.class.size() <= 50 &&
             data.text is string && data.text.size() <= 2000 &&
             data.options is map && data.options.keys().hasAll(['A', 'B', 'C', 'D']) &&
             data.options.A is string && data.options.A.size() <= 500 &&
             data.options.B is string && data.options.B.size() <= 500 &&
             data.options.C is string && data.options.C.size() <= 500 &&
             data.options.D is string && data.options.D.size() <= 500 &&
             data.correctAnswer is string && data.correctAnswer.size() <= 1 &&
             data.createdAt == request.time;
    }
    
    function isValidScore(data) {
      // studentId, studentName, admissionNo, session, term, class, arm, subject, ca, exam, total, grade, updatedAt = 13 fields (ScoreEntry uses new Date(), which translates to timestamp)
      return data.keys().hasAll(['studentId', 'studentName', 'admissionNo', 'session', 'term', 'class', 'arm', 'subject', 'ca', 'exam', 'total', 'grade', 'updatedAt']) &&
             data.size() == 13 &&
             data.studentId is string && data.studentId.size() <= 100 &&
             data.studentName is string && data.studentName.size() <= 200 &&
             data.admissionNo is string && data.admissionNo.size() <= 50 &&
             data.session is string && data.session.size() <= 20 &&
             data.term is string && data.term.size() <= 20 &&
             data.class is string && data.class.size() <= 50 &&
             data.arm is string && data.arm.size() <= 10 &&
             data.subject is string && data.subject.size() <= 100 &&
             data.ca is number && data.ca >= 0 && data.ca <= 40 &&
             data.exam is number && data.exam >= 0 && data.exam <= 60 &&
             data.total is number && data.total == (data.ca + data.exam) &&
             data.grade is string && data.grade.size() <= 2 &&
             data.updatedAt is timestamp;
    }
    
    function isValidCBTResult(data) {
      // studentId, studentName, class, score, total, percentage, date = 7 fields
      return data.keys().hasAll(['studentId', 'studentName', 'class', 'score', 'total', 'percentage', 'date']) &&
             data.size() == 7 &&
             data.studentId is string && data.studentId.size() <= 100 &&
             data.studentName is string && data.studentName.size() <= 200 &&
             data.class is string && data.class.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.total is number && data.total > 0 &&
             data.percentage is number && data.percentage >= 0 && data.percentage <= 100 &&
             data.date == request.time;
    }

    // Collections
    match /students/{studentId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidStudent(incoming());
      allow update: if isAdmin() && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'admissionNo', 'class', 'arm', 'gender']) &&
                    incoming().name is string && incoming().name.size() <= 200 &&
                    incoming().admissionNo is string && incoming().admissionNo.size() <= 50 &&
                    incoming().class is string && incoming().class.size() <= 50 &&
                    incoming().arm is string && incoming().arm.size() <= 10 &&
                    incoming().gender is string && incoming().gender.size() <= 20;
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && request.resource.data.keys().hasAll(['subject', 'class', 'text', 'answer', 'difficulty', 'createdAt']);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /scores/{scoreId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidScore(incoming());
      allow delete: if isAdmin();
    }

    match /cbt_results/{resultId} {
      allow create: if isValidCBTResult(incoming());
      allow get, list, update, delete: if isAdmin();
    }
  }
}
